{
  "name": "imessage",
  "label": "iMessage",
  "description": "Receive SMS and iMessage messages",
  "icon": "📱",
  "version": "1.0.0",
  "platform": "darwin",
  "permissions": [
    { "name": "messages", "label": "Messages", "app": "Messages", "reason": "Read incoming SMS and iMessage messages" }
  ],
  "receivers": [{
    "name": "imessage",
    "mode": "polling",
    "source": "sms",
    "pollInterval": 300000,
    "entry": "./receiver.ts"
  }]
}
