{
  "name": "whatsapp",
  "label": "WhatsApp",
  "description": "Send and receive WhatsApp messages",
  "icon": "💬",
  "version": "1.0.0",
  "capabilities": [
    "Read WhatsApp messages",
    "Search conversations",
    "Send messages",
    "Send media files",
    "Receive incoming messages"
  ],
  "mcpServers": [{
    "name": "whatsapp",
    "command": "npx",
    "args": ["-y", "whatsapp-mcp"],
    "envFromConfig": { "WACLI_PATH": "wacliPath" }
  }],
  "receivers": [{
    "name": "whatsapp-wacli",
    "mode": "long-running",
    "source": "whatsapp",
    "entry": "./receiver.ts"
  }],
  "setup": {
    "authCommand": "wacli auth",
    "checkCommand": "which wacli",
    "configFields": [
      { "key": "wacliPath", "label": "wacli path", "type": "text", "placeholder": "/usr/local/bin/wacli" }
    ]
  },
  "toolPermissions": {
    "scope": "per-call",
    "safe": ["mcp__whatsapp__list_chats", "mcp__whatsapp__read_messages", "mcp__whatsapp__search"],
    "critical": ["mcp__whatsapp__send_message", "mcp__whatsapp__send_media"]
  }
}
