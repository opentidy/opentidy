{
  "name": "whatsapp",
  "label": "WhatsApp",
  "description": "Send and receive WhatsApp messages",
  "icon": "💬",
  "version": "1.0.0",
  "mcpServers": [{
    "name": "whatsapp",
    "command": "npx",
    "args": ["-y", "whatsapp-mcp"],
    "envFromConfig": { "WACLI_PATH": "wacliPath" }
  }],
  "receivers": [{
    "name": "whatsapp-wacli",
    "mode": "long-running",
    "source": "whatsapp",
    "entry": "./receiver.ts"
  }],
  "setup": {
    "authCommand": "wacli auth",
    "checkCommand": "which wacli",
    "configFields": [
      { "key": "wacliPath", "label": "wacli path", "type": "text", "placeholder": "/usr/local/bin/wacli" }
    ]
  },
  "toolPermissions": {
    "scope": "per-call",
    "safe": [
      { "tool": "mcp__whatsapp__list_chats", "label": "List conversations" },
      { "tool": "mcp__whatsapp__read_messages", "label": "Read messages" },
      { "tool": "mcp__whatsapp__search", "label": "Search messages" }
    ],
    "critical": [
      { "tool": "mcp__whatsapp__send_message", "label": "Send messages" },
      { "tool": "mcp__whatsapp__send_media", "label": "Send media files" }
    ]
  }
}
