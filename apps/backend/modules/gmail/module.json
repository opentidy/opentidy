{
  "name": "gmail",
  "label": "Gmail",
  "description": "Read, search, and draft emails via Gmail",
  "icon": "📧",
  "version": "1.0.0",
  "mcpServers": [{
    "name": "gmail",
    "command": "npx",
    "args": ["-y", "@gongrzhe/server-gmail-autoauth-mcp"]
  }],
  "receivers": [{
    "name": "gmail-webhook",
    "mode": "webhook",
    "source": "gmail",
    "transform": "./transform.ts"
  }],
  "setup": {
    "authCommand": "npx -y @gongrzhe/server-gmail-autoauth-mcp auth",
    "checkCommand": "test -f ~/.gmail-mcp/credentials.json"
  },
  "toolPermissions": {
    "scope": "per-call",
    "safe": [
      { "tool": "mcp__gmail__search", "label": "Search inbox" },
      { "tool": "mcp__gmail__read_message", "label": "Read emails" },
      { "tool": "mcp__gmail__list_labels", "label": "List labels" },
      { "tool": "mcp__gmail__get_message", "label": "Get email details" }
    ],
    "critical": [
      { "tool": "mcp__gmail__send", "label": "Send emails" },
      { "tool": "mcp__gmail__reply", "label": "Reply to emails" },
      { "tool": "mcp__gmail__draft", "label": "Draft emails" },
      { "tool": "mcp__gmail__forward", "label": "Forward emails" }
    ]
  }
}
