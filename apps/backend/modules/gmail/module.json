{
  "name": "gmail",
  "label": "Gmail",
  "description": "Read, search, and draft emails via Gmail",
  "icon": "📧",
  "version": "1.0.0",
  "mcpServers": [{
    "name": "gmail",
    "command": "npx",
    "args": ["-y", "@gongrzhe/server-gmail-autoauth-mcp"]
  }],
  "receivers": [{
    "name": "gmail-webhook",
    "mode": "webhook",
    "source": "gmail",
    "transform": "./transform.ts"
  }],
  "setup": {
    "authCommand": "npx -y @gongrzhe/server-gmail-autoauth-mcp auth",
    "checkCommand": "test -f ~/.gmail-mcp/credentials.json"
  },
  "toolPermissions": {
    "scope": "per-call",
    "safe": ["mcp__gmail__search", "mcp__gmail__read_message", "mcp__gmail__list_labels", "mcp__gmail__get_message"],
    "critical": ["mcp__gmail__send", "mcp__gmail__reply", "mcp__gmail__draft", "mcp__gmail__forward"]
  }
}
